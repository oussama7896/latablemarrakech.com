# Copy this file to .env.deploy and fill in your Hostinger credentials.
# .env.deploy is gitignored.
#
# Find these in hPanel → Files → FTP Accounts.

# FTP server, usually one of:
#   ftp.<your-domain>.com
#   files.<something>.hostinger.com
HOSTINGER_HOST=ftp.latablemarrakech.com

# Your FTP username (often u123456789 or username@yourdomain.com)
HOSTINGER_USER=u123456789

# Your FTP password — keep this secret
HOSTINGER_PASS=changeme

# Path to upload into. Hostinger's web root is usually /public_html
HOSTINGER_REMOTE_PATH=/public_html

# Protocol: "ftp" (default, port 21) or "sftp" (port 22, requires SSH access)
HOSTINGER_PROTOCOL=ftp

# Optional: override the default port (21 for ftp, 22 for sftp)
# HOSTINGER_PORT=21
