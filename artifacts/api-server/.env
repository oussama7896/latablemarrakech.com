# Fill these with your real values (DO NOT commit secrets to git)
GOOGLE_SHEETS_SPREADSHEET_ID=REPLACE_ME_SPREADSHEET_ID
# Put the full JSON object as a single line. Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=REPLACE_ME_SERVICE_ACCOUNT_JSON
GOOGLE_SHEETS_RANGE=Sheet1!A:L

WHATSAPP_META_PHONE_NUMBER_ID=REPLACE_ME_WA_PHONE_NUMBER_ID
WHATSAPP_API_TOKEN=REPLACE_ME_WA_API_TOKEN
WHATSAPP_TARGET_NUMBER=REPLACE_ME_TARGET_NUMBER

# Optional Twilio WhatsApp fallback. If you use Twilio, set these as well.
TWILIO_ACCOUNT_SID=REPLACE_ME_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_ME_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=REPLACE_ME_TWILIO_WHATSAPP_FROM
TWILIO_WHATSAPP_TO=REPLACE_ME_TWILIO_WHATSAPP_TO

PORT=5000
