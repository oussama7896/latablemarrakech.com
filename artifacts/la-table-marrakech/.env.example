# Vite environment variables for the la-table-marrakech frontend.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real tracking IDs to the repo.
#
# These IDs are read at BUILD TIME by index.html (Vite replaces the
# %VITE_X% placeholders). Setting one but not the other is fine:
#
#   - VITE_GTM_ID set, VITE_GA4_ID set       → GTM is injected; configure
#                                              GA4 inside the GTM container.
#                                              Don't ALSO inject GA4 directly
#                                              or you'll double-count.
#   - VITE_GTM_ID set, VITE_GA4_ID unset     → GTM only.
#   - VITE_GTM_ID unset, VITE_GA4_ID set     → GA4 only (direct gtag).
#   - Both unset                              → no tracking installed; the
#                                              dataLayer queue still works.
#
# Find IDs at:
#   GTM:  https://tagmanager.google.com → Admin → Container ID
#   GA4:  Google Analytics → Admin → Data Streams → Web → Measurement ID

# Google Tag Manager container ID (preferred — manages everything from the UI)
VITE_GTM_ID=

# Google Analytics 4 measurement ID (only set if NOT using GTM, or you
# want GA4 separate. Inside GTM, leave this blank.)
VITE_GA4_ID=
